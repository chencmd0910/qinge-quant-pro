# Auto-normalize line endings to LF on commit
* text=auto eol=lf

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Config/text files
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf
*.txt text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.gz binary
*.tar binary
*.zip binary
*.db binary
*.sqlite binary
*.parquet binary
